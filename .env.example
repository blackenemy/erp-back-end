# ═══════════════════════════════════════════════════════════════════
# Mini Pricing Platform — Environment Configuration Example
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and modify values as needed
# Usage: export $(cat .env | xargs) OR source .env

# ─────────────────────────────────────────────────────────────────────
# Services
# ─────────────────────────────────────────────────────────────────────

# RuleService configuration
RULE_SERVICE_PORT=5002
RULE_SERVICE_HOST=localhost
RULE_SERVICE_URL=http://localhost:5002

# PricingService configuration
PRICING_SERVICE_PORT=5001
PRICING_SERVICE_HOST=localhost
PRICING_SERVICE_LOG_LEVEL=Information

# ─────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────

# Log level: Trace, Debug, Information, Warning, Error, Critical
LOG_LEVEL=Information
LOG_LEVEL_MICROSOFT=Warning

# Enable structured logging (JSON format)
STRUCTURED_LOGGING=true

# Log output directory
LOG_PATH=./logs

# ─────────────────────────────────────────────────────────────────────
# Data Storage
# ─────────────────────────────────────────────────────────────────────

# Rules storage path
RULES_FILE_PATH=./data/rules.json

# Jobs storage path
JOBS_FILE_PATH=./data/jobs.json

# ─────────────────────────────────────────────────────────────────────
# Environment
# ─────────────────────────────────────────────────────────────────────

# ASPNETCORE_ENVIRONMENT: Development, Staging, Production
ASPNETCORE_ENVIRONMENT=Development

# Enable detailed error pages (Development only)
SHOW_DETAILED_ERRORS=true

# ─────────────────────────────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────────────────────────────

# COMPOSE_PROJECT_NAME is set in docker-compose.yml
COMPOSE_PROJECT_NAME=erp

# Docker network
DOCKER_NETWORK=erp_default

# ─────────────────────────────────────────────────────────────────────
# Optional: Rate limiting & Retry
# ─────────────────────────────────────────────────────────────────────

# Max requests per minute (per IP)
RATE_LIMIT_PER_MINUTE=100

# HTTP client timeout (seconds)
HTTP_CLIENT_TIMEOUT_SECONDS=30

# Retry policy: max attempts for transient failures
RETRY_MAX_ATTEMPTS=3
